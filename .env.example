# =========================
# 应用基础配置
# =========================
# 服务名称（用于日志与监控标识）
APP_NAME=rag-bot-demo
# 运行环境：dev/test/prod
APP_ENV=dev
# 服务监听地址（容器建议 0.0.0.0）
APP_HOST=0.0.0.0
# 服务端口
APP_PORT=8000
# 日志级别：DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# =========================
# Weaviate 向量库配置
# =========================
# Weaviate HTTP 地址
WEAVIATE_URL=http://localhost:8080
# Weaviate API Key（无鉴权可留空）
WEAVIATE_API_KEY=
# 向量集合名（上线后建议保持稳定）
WEAVIATE_COLLECTION=KnowledgeChunk
# Weaviate gRPC 主机
WEAVIATE_GRPC_HOST=localhost
# Weaviate gRPC 端口
WEAVIATE_GRPC_PORT=50051
# gRPC 是否启用 TLS（生产建议 true）
WEAVIATE_GRPC_SECURE=false

# =========================
# DeepSeek 大模型配置
# =========================
# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek API Key（必须在本地 .env 配置）
DEEPSEEK_API_KEY=
# 聊天模型名称
DEEPSEEK_CHAT_MODEL=deepseek-chat
# 请求超时（秒）
DEEPSEEK_TIMEOUT_SECONDS=60

# =========================
# Ollama Embedding 配置
# =========================
# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434
# Embedding 模型名称（建议固定版本，避免 latest 漂移）
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest
# Embedding provider 标识（用于 Mongo embedding 缓存键）
EMBEDDING_PROVIDER=ollama
# Embedding 模型统一标识（为空时回退到 OLLAMA_EMBEDDING_MODEL）
EMBEDDING_MODEL=
# 请求超时（秒）
OLLAMA_TIMEOUT_SECONDS=60

# =========================
# RAG 检索与重排配置
# =========================
# 切片长度（中文常见 400~1200）
RAG_CHUNK_SIZE=1000
# 切片重叠（建议 chunk_size 的 15%~30%）
RAG_CHUNK_OVERLAP=200
# 粗召回 Top-K（CPU 推荐 8~12）
RAG_RETRIEVAL_TOP_K=8
# 重排后保留 Top-N（常见 3~5）
RAG_RERANK_TOP_N=4
# 重排最低分阈值（建议从 0.12~0.20 调）
RAG_RERANK_MIN_SCORE=0.15
# 全部低分时最少保留条数（0=严格拒答）
RAG_MIN_CHUNKS_KEEP=1
# 是否记录重排分数日志（调参阶段建议 true）
RAG_LOG_RERANK_SCORES=true
# 每次日志最多展示多少条样本
RAG_RERANK_SCORE_LOG_MAX_ITEMS=3
# 是否启用问题改写
RAG_ENABLE_REWRITE=true
# 是否启用重排
RAG_ENABLE_RERANK=true

# =========================
# FlashRank 配置
# =========================
# 重排模型名称（中文可尝试 BAAI/bge-reranker-base）
FLASHRANK_MODEL_NAME=ms-marco-MiniLM-L-12-v2
# FlashRank 模型缓存目录
FLASHRANK_CACHE_DIR=.cache/flashrank
# 是否仅离线加载模型（生产建议 true）
FLASHRANK_OFFLINE_ONLY=true
# 单条候选最大字符数（CPU 推荐 600~1200）
FLASHRANK_MAX_PASSAGE_CHARS=1200

# =========================
# MongoDB 配置
# =========================
# Mongo 连接串
MONGODB_URI=mongodb://localhost:27017
# 数据库名称（不同环境建议分库）
MONGODB_DB_NAME=rag_bot_demo
# 聊天消息集合
MONGODB_CHAT_COLLECTION=chat_messages
# 用户画像集合
MONGODB_PROFILE_COLLECTION=chat_profiles
# 文档块元数据集合
MONGODB_CHUNK_COLLECTION=kb_chunks
# Embedding 缓存集合（存向量 + provider/model + text_hash）
MONGODB_EMBEDDING_COLLECTION=kb_embeddings

# =========================
# 多轮记忆配置
# =========================
# 历史对话最大轮数
RAG_HISTORY_MAX_TURNS=6
# 记忆总开关
MEMORY_ENABLE=false
# 用户画像开关
MEMORY_PROFILE_ENABLE=false
# 短期历史 token 上限
MEMORY_SHORT_MAX_TOKENS=1200
# 注入画像最大条目数
MEMORY_PROFILE_MAX_ITEMS=6

# =========================
# Ingest 导入配置
# =========================
# 单文件导入大小上限（MB）
INGEST_MAX_FILE_SIZE_MB=20
